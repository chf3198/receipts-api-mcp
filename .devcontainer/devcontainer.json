{
  "name": "receipts-api-mcp",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "postStartCommand": "pip install uv && uv sync && uv run uvicorn receipts_api.main:app --host 0.0.0.0 --port 8000 &",
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "Receipts API",
      "onAutoForward": "notify",
      "visibility": "public"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff"
      ]
    }
  }
}
